NODE_ENV=production

# Para publicar por IP en un VPS, deja SITE_ADDRESS=:80.
# Si tienes dominio, usa por ejemplo: SITE_ADDRESS=cepets.midominio.com
SITE_ADDRESS=:80

# En un VPS real usa 80 y 443. Para pruebas locales puedes cambiarlos a 8080 y 8443.
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443

POSTGRES_DB=cepets
POSTGRES_USER=cepets
POSTGRES_PASSWORD=replace-with-a-strong-password

JWT_SECRET=replace-with-a-long-random-secret
INTERNAL_SERVICE_KEY=replace-with-another-long-random-secret
