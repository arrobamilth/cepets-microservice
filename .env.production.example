NODE_ENV=production

# Usa :80 para pruebas locales. En servidor cambia a tu dominio, por ejemplo:
# SITE_ADDRESS=cepets.midominio.com
SITE_ADDRESS=:80

# Para un VPS real usa 80 y 443.
PUBLIC_HTTP_PORT=8080
PUBLIC_HTTPS_PORT=8443

POSTGRES_DB=cepets
POSTGRES_USER=cepets
POSTGRES_PASSWORD=replace-with-a-strong-password

JWT_SECRET=replace-with-a-long-random-secret
INTERNAL_SERVICE_KEY=replace-with-another-long-random-secret
